{
  "expo": {
    "name": "Box Breathing 4min",
    "slug": "box-breathing",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "box-breathing",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.boxbreathing.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.boxbreathing.app",
      "versionCode": 2,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router"
    ]
  }
}
